# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/velabeam

# NextAuth
AUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# Stripe (optional — billing returns 501 without this)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Google Places (optional — shows configure-provider empty state without this)
GOOGLE_PLACES_API_KEY=

# OpenAI or LLM provider (optional — site generation returns stub without this)
OPENAI_API_KEY=

# MapLibre tile server (optional — uses default OSM dark)
NEXT_PUBLIC_MAP_TILE_URL=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
